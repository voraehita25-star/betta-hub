# ============================================================
# BettaHub — environment variables
# ============================================================
# คัดลอกเป็น .env.local (gitignored) สำหรับ dev
# ตั้งที่ Vercel Project Settings → Environment Variables สำหรับ production
# (หรือใช้ `vercel env add <NAME> production`)
#
# NEXT_PUBLIC_*  → ถูก embed ใน client bundle ตอน build (ปลอดภัยที่จะเห็น)
# ============================================================

# ฟีเจอร์ "แจ้งลิงก์เสีย/สินค้าหมด" → บันทึกลง Vercel Blob, ดูได้ที่ /dev/reports
# 1 = แสดงปุ่มแจ้งในการ์ดสินค้า; เว้นว่าง = ซ่อนปุ่ม (กันปุ่มเสียก่อนต่อ Blob store)
NEXT_PUBLIC_REPORTS_ENABLED=

# token ฝั่งเซิร์ฟเวอร์สำหรับเข้าหน้า /dev/reports (ตั้งให้ยาว/เดายาก) — ห้ามขึ้นต้นด้วย NEXT_PUBLIC_
DEV_REPORTS_TOKEN=

# Vercel Blob — ได้อัตโนมัติเมื่อ connect Blob store กับโปรเจกต์ (Storage → Blob)
# ใส่ค่าจริงใน .env.local เพื่อทดสอบ persistence ในเครื่อง
BLOB_READ_WRITE_TOKEN=

# โดเมนของเว็บใน production (no trailing slash)
# ปล่อยว่างใน dev → ตกเป็น http://localhost:3000
# ปล่อยว่างบน Vercel → fallback: VERCEL_PROJECT_PRODUCTION_URL (โดเมน prod เสถียร) ก่อน แล้วจึง VERCEL_URL (ต่อ deploy)
NEXT_PUBLIC_SITE_URL=

# ยืนยันความเป็นเจ้าของเว็บ (SEO) — ปล่อยว่าง = ไม่ emit meta tag (ปลอดภัยที่จะ ship ไว้ก่อน)
# Google: Search Console → Add property → ยืนยันแบบ "HTML tag" → คัดเฉพาะค่า content ของ google-site-verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing: Bing Webmaster Tools → Add site (หรือ Import จาก Google Search Console) → คัดค่า content ของ meta msvalidate.01
NEXT_PUBLIC_BING_SITE_VERIFICATION=
